---
import '../styles/globals.css';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/sections/Hero';
import Projects from '../components/sections/Projects';
import DeployFlow from '../components/sections/DeployFlow';
import StackSection from '../components/sections/StackSection';
import Timeline from '../components/sections/Timeline';
import FinalCTA from '../components/sections/FinalCTA';
---

<Layout
  title="Lucas Padilha — DevOps, Cloud & Infrastructure Automation"
  description="Lucas Padilha portfolio with practical projects in AWS, Terraform, Ansible, Docker, CI/CD and infrastructure automation."
  ogImage="/og-image-placeholder.jpg"
>
  <Hero client:load />
  <main>
    <Projects client:visible />
    <DeployFlow client:visible />
    <StackSection client:visible />
    <Timeline client:visible />
    <FinalCTA client:visible />
  </main>
</Layout>
